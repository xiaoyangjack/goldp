#!/bin/bash

# 获取应用程序包所在目录
APP_PATH="$0"
APP_DIR="$(dirname "$APP_PATH")"
CONTENTS_DIR="$(dirname "$APP_DIR")"
PROJECT_DIR="$(dirname "$CONTENTS_DIR")/GoldQuant"

cd "$PROJECT_DIR"

# 激活虚拟环境
if [ -d "../gold_quant_env" ]; then
    source ../gold_quant_env/bin/activate
elif [ -d "gold_quant_env" ]; then
    source gold_quant_env/bin/activate
fi

# 启动Flask服务
exec python web_app.py
