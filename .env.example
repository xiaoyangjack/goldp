# Flask配置
FLASK_PORT=5555
FLASK_HOST=0.0.0.0
FLASK_DEBUG=False

# 数据配置
DATA_PATH=data/gold_au9999_verified.csv
DATA_REFRESH_INTERVAL=60

# 缓存配置
CACHE_ENABLED=True
CACHE_TIMEOUT=300

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=7 days

# 量化参数
ATR_PERIOD=14
MA_SHORT_PERIOD=10
MA_LONG_PERIOD=30
GRID_LAYERS=6
GRID_MULTIPLIER=1.5

# 风控参数
RISK_SINGLE_TRADE=1.0
RISK_DAILY_LIMIT=3.0
RISK_WEEKLY_LIMIT=8.0
RISK_CONSECUTIVE_LOSS=4
